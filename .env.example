# =============================================================================
# Government Workforce Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to .env and populate values for local development.
# NEVER commit .env to version control.
# All secrets must be rotated before production deployment.
# References: spec/07_security_architecture.md, environment/03_secrets_management.md
# =============================================================================

# -----------------------------------------------------------------------------
# Database (FR-001 through FR-005 — Identity & Access foundation)
# Populated: Milestone 2 — Database Foundation
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://govplatform:devpassword@localhost:5433/gov_workforce_dev

# Docker Compose postgres service credentials (must match DATABASE_URL)
POSTGRES_USER=govplatform
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=gov_workforce_dev
POSTGRES_PORT=5433

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------------
# JWT Authentication (FR-002, FR-004 — Authentication & Session Management)
# Populated: Milestone 5 — Authentication Foundation
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Frontend
# Populated: Milestone 4 — Frontend Foundation
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Server-side only — used by Next.js Route Handlers to call NestJS
# NOT a browser variable; do not use NEXT_PUBLIC_ prefix
# Docker: overridden to http://api:3001 in docker-compose.yml (container-to-container via service name)
# Populated: Milestone 10 — Frontend Foundation
API_URL=http://localhost:3001
