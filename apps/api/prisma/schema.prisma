// =============================================================================
// Government Workforce Intelligence Platform — Prisma Schema
// Milestone 2: Database Foundation
// Reference: spec/05_database_schema.md, execution/02_phase_1_foundation.md
// =============================================================================
//
// PostgreSQL schemas declared here (Milestone 2 scope):
//   organization — tenants (multi-tenant root; spec: organization.agencies)
//   identity     — users, roles, permissions, role_permissions, user_roles
//   audit        — audit_events (immutable audit trail)
//
// Future schemas added progressively as domains are implemented:
//   workforce, scheduling, recruiting, intelligence, compliance, integration
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "organization", "audit", "workforce", "recruiting", "intelligence"]
}

// ---------------------------------------------------------------------------
// Schema: organization
// Tenant root entity. Every tenant-scoped table carries tenant_id UUID
// referencing this table.
// Spec reference: spec/05_database_schema.md — Schema: organization / agencies
// The platform treats agency and tenant as the same concept at the DB level.
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(100)
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users       User[]
  departments Department[]

  @@map("tenants")
  @@schema("organization")
}

// ---------------------------------------------------------------------------
// Schema: organization — Department
// Spec reference: spec/05_database_schema.md — Schema: organization / departments
// Approved decisions:
//   - code VARCHAR(100) with tenant-scoped unique constraint (Decision 2)
//   - deleted_at per platform soft-delete convention (Decision 3)
//   - agencyId column omitted: Tenant IS Agency (ORG-006); tenantId serves both
//     tenant isolation and agency association roles — adding a separate agencyId
//     FK to the same Tenant row would be redundant.
// ---------------------------------------------------------------------------

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @db.VarChar(100)
  description String?   @db.Text
  status      String    @default("ACTIVE") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  positions Position[]
  employees Employee[]

  @@unique([tenantId, code], map: "idx_departments_tenant_code")
  @@index([tenantId], map: "idx_departments_tenant")
  @@map("departments")
  @@schema("organization")
}

// ---------------------------------------------------------------------------
// Schema: workforce
// Spec reference: spec/05_database_schema.md — Schema: workforce / positions
// Milestone 8: Position Management Foundation (FR-100)
// Approved decisions:
//   - status default DRAFT per full 4-state lifecycle (Decision 1: DRAFT/ACTIVE/FROZEN/CLOSED)
//   - tenantId as bare scalar (no Prisma relation to Tenant) — isolation enforced at query level
//   - departmentId FK to organization.departments — cross-schema relation (multiSchema preview)
//   - deleted_at per platform soft-delete convention
//   - skills/certifications deferred (Decision 3)
// ---------------------------------------------------------------------------

model Position {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  departmentId   String    @map("department_id") @db.Uuid
  title          String    @db.VarChar(255)
  classification String?   @db.VarChar(100)
  salaryBand     String?   @map("salary_band") @db.VarChar(100)
  status         String    @default("DRAFT") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id])
  vacancies  Vacancy[]
  employees  Employee[]

  @@index([tenantId], map: "idx_positions_tenant")
  @@index([departmentId], map: "idx_positions_department")
  @@map("positions")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Vacancy
// Spec reference: spec/05_database_schema.md — Schema: workforce / vacancies
// Milestone 11: Vacancy Management (FR-103, FR-104)
// Approved governance decisions:
//   - status/priority/reason stored as VARCHAR per platform convention (no Prisma enums)
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level
//   - filledAt added (not in spec/05): required for Time To Fill metric (directives/03 Reporting Rules)
//   - deleted_at per platform soft-delete convention
//   - 4 indexes: position, status, tenant, createdAt (last two governance additions to spec/05 gaps)
// ---------------------------------------------------------------------------

model Vacancy {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  positionId       String    @map("position_id") @db.Uuid
  priority         String?   @db.VarChar(50)
  reason           String?   @db.VarChar(100)
  status           String    @default("DRAFT") @db.VarChar(50)
  expectedFillDate DateTime? @map("expected_fill_date") @db.Date
  filledAt         DateTime? @map("filled_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  position     Position      @relation(fields: [positionId], references: [id], map: "fk_vacancy_position")
  applications Application[]

  @@index([tenantId], map: "idx_vacancies_tenant")
  @@index([positionId], map: "idx_vacancies_position")
  @@index([status], map: "idx_vacancies_status")
  @@index([createdAt], map: "idx_vacancies_created")
  @@map("vacancies")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Employee
// Spec reference: spec/05_database_schema.md — Schema: workforce / employees
// Milestone 12: Employee Management Foundation (FR-110, FR-111, FR-112)
// Milestone 15: Position Linkage (GD-M15-1)
// Approved governance decisions:
//   - employmentStatus @default("PENDING_ONBOARDING") per GD-M12-1 canonical values
//   - employmentStatus stored as VARCHAR per platform convention (no Prisma enum)
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
//   - departmentId FK to organization.departments — cross-schema relation (multiSchema preview)
//   - employeeNumber nullable at DB level per spec/05; required at API level per GD-M12-6
//   - employeeNumber immutable after creation per GD-M12-6 (enforced at service layer)
//   - positionId: UUID NULL FK → workforce.positions (GD-M15-1 D2; GD-PRE-M13-002 D1)
//     No DB unique constraint — 1:1 FTE Slot Model enforced at service layer only
//     Partial index (WHERE NOT NULL) in migration SQL; @@index here is the Prisma representation
//   - appointmentAuthority: VARCHAR(50) NOT NULL (GD-M15-1 D1); backfilled ADMINISTRATIVE
//     for pre-M15 records per GD-M15-1 D3; immutable after creation (GD-PRE-M13-001 D4)
//   - deleted_at per platform soft-delete convention
// ---------------------------------------------------------------------------

model Employee {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  departmentId         String    @map("department_id") @db.Uuid
  positionId           String?   @map("position_id") @db.Uuid
  employeeNumber       String?   @map("employee_number") @db.VarChar(100)
  firstName            String    @map("first_name") @db.VarChar(100)
  lastName             String    @map("last_name") @db.VarChar(100)
  email                String?   @db.VarChar(255)
  employmentStatus     String    @default("PENDING_ONBOARDING") @map("employment_status") @db.VarChar(50)
  appointmentAuthority String    @map("appointment_authority") @db.VarChar(50)
  hireDate             DateTime? @map("hire_date") @db.Date
  terminationDate      DateTime? @map("termination_date") @db.Date
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id])
  position   Position?  @relation(fields: [positionId], references: [id], map: "fk_employee_position")

  employeeSkills         EmployeeSkill[]
  employeeCertifications EmployeeCertification[]

  @@unique([tenantId, employeeNumber], map: "idx_employee_number_tenant")
  @@index([tenantId], map: "idx_employees_tenant")
  @@index([positionId], map: "idx_employees_position")
  @@map("employees")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Skill
// Spec reference: spec/05_database_schema.md — Schema: workforce / skills
// Milestone 13: Skills & Certifications Foundation (FR-113, FR-150)
// Governance decisions:
//   - tenant_id per GD-M13-1 Decision 2 (spec deviation — correction of spec oversight)
//   - created_at, updated_at, deleted_at per GD-M13-1 Decision 7 (shared column confirmation)
//   - tenant-scoped unique constraint on name per GD-M13-2 Decision 8
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
// ---------------------------------------------------------------------------

model Skill {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  category    String?   @db.VarChar(100)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  employeeSkills EmployeeSkill[]

  @@unique([tenantId, name], map: "idx_skills_tenant_name")
  @@index([tenantId], map: "idx_skills_tenant")
  @@map("skills")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Certification
// Spec reference: spec/05_database_schema.md — Schema: workforce / certifications
// Milestone 13: Skills & Certifications Foundation (FR-114, FR-151, FR-153)
// Governance decisions:
//   - tenant_id per GD-M13-1 Decision 2 (spec deviation — correction of spec oversight)
//   - created_at, updated_at, deleted_at per GD-M13-1 Decision 7 (shared column confirmation)
//   - tenant-scoped unique constraint on name per GD-M13-2 Decision 9
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
// ---------------------------------------------------------------------------

model Certification {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  name               String    @db.VarChar(255)
  issuer             String?   @db.VarChar(255)
  expirationRequired Boolean   @default(false) @map("expiration_required")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  employeeCertifications EmployeeCertification[]

  @@unique([tenantId, name], map: "idx_certifications_tenant_name")
  @@index([tenantId], map: "idx_certifications_tenant")
  @@map("certifications")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — EmployeeSkill
// Spec reference: spec/05_database_schema.md — Schema: workforce / employee_skills
// Milestone 13: Skills & Certifications Foundation (FR-113, FR-150)
// Governance decisions:
//   - Composite PK (employee_id, skill_id) per spec/05 and GD-M13-4 Decision 2
//   - proficiency_level: one of BEGINNER/DEVELOPING/PROFICIENT/ADVANCED/EXPERT
//     (GD-M13-2 Decision 6, directives/14 SKL-210); validated at service layer
//   - verified_at null = self-declared; set = HR-verified (directives/14 SKL-211)
//   - No tenant_id column — isolation derived through employee FK chain (GD-M13-1 Decision 7)
// ---------------------------------------------------------------------------

model EmployeeSkill {
  employeeId       String    @map("employee_id") @db.Uuid
  skillId          String    @map("skill_id") @db.Uuid
  proficiencyLevel String?   @map("proficiency_level") @db.VarChar(50)
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id])
  skill    Skill    @relation(fields: [skillId], references: [id])

  @@id([employeeId, skillId])
  @@index([employeeId], map: "idx_employee_skills_employee")
  @@index([skillId], map: "idx_employee_skills_skill")
  @@map("employee_skills")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — EmployeeCertification
// Spec reference: spec/05_database_schema.md — Schema: workforce / employee_certifications
// Milestone 13: Skills & Certifications Foundation (FR-114, FR-151, FR-153)
// Governance decisions:
//   - Composite PK (employee_id, certification_id) per spec/05 and GD-M13-4 Decision 2
//   - status VARCHAR(50); canonical values: ACTIVE, EXPIRED, REVOKED (GD-M13-3)
//   - status DEFAULT "ACTIVE" per GD-M13-3 Decision 2
//   - REVOKED is terminal; transition enforcement at service layer (CRT-301)
//   - issue_date and expiration_date stored as DATE per spec/05
//   - No tenant_id column — isolation derived through employee FK chain (GD-M13-1 Decision 7)
//   - expirationDate index: supports FR-153 expiration tracking queries (GD-M13-3 Decision 4)
// ---------------------------------------------------------------------------

model EmployeeCertification {
  employeeId      String    @map("employee_id") @db.Uuid
  certificationId String    @map("certification_id") @db.Uuid
  status          String    @default("ACTIVE") @map("status") @db.VarChar(50)
  issueDate       DateTime? @map("issue_date") @db.Date
  expirationDate  DateTime? @map("expiration_date") @db.Date

  employee      Employee      @relation(fields: [employeeId], references: [id])
  certification Certification @relation(fields: [certificationId], references: [id])

  @@id([employeeId, certificationId])
  @@index([employeeId], map: "idx_employee_certifications_employee")
  @@index([certificationId], map: "idx_employee_certifications_certification")
  @@index([status], map: "idx_employee_certifications_status")
  @@index([expirationDate], map: "idx_employee_certifications_expiration")
  @@map("employee_certifications")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: identity
// Spec reference: spec/05_database_schema.md — Schema: identity
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  status              String    @default("INVITED") @db.VarChar(50)
  lastLoginAt         DateTime? @map("last_login_at")         @db.Timestamptz(6)
  failedLoginAttempts Int       @default(0)                   @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")          @db.Timestamptz(6)
  createdAt           DateTime  @default(now())               @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, email], map: "idx_users_tenant_email")
  @@index([tenantId], map: "idx_users_tenant")
  @@map("users")
  @@schema("identity")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
  @@schema("identity")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
  @@schema("identity")
}

// Role → Permission assignment (many-to-many)
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

// User → Role assignment (many-to-many)
model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("identity")
}

// ---------------------------------------------------------------------------
// Schema: recruiting — Candidate
// Governance authority: GD-PRE-PHASE3-002 Decision 3 (canonical schema authority)
//                       GD-M16-1 Decision 4 (schema scope for M16)
// Milestone 16: Candidate Management Foundation (FR-300 partial)
// Approved decisions:
//   - tenantId bare scalar — isolation enforced at query level (SEC-003; GD-PRE-PHASE3-002 D1)
//   - tenantId derived from JWT only; never from request body; never in API responses
//   - status VARCHAR(50) default ACTIVE; values: ACTIVE, ARCHIVED
//     Only ACTIVE → ARCHIVED transition allowed; archive endpoint only
//   - deleted_at per platform soft-delete convention (GD-PRE-PHASE3-002 D2)
//   - EMAIL UNIQUENESS: enforced as partial unique index in migration SQL
//     (WHERE deleted_at IS NULL) to allow re-applicant scenario (GD-M16-1 D5).
//     DO NOT add @@unique([tenantId, email]) — Prisma would generate a full
//     non-partial unique constraint, blocking re-applicants whose prior record
//     is archived. Uniqueness is @@index here; partial UNIQUE enforced in SQL.
// ---------------------------------------------------------------------------

model Candidate {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  firstName String    @map("first_name") @db.VarChar(100)
  lastName  String    @map("last_name") @db.VarChar(100)
  email     String    @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  status    String    @default("ACTIVE") @db.VarChar(50)
  source    String?   @db.VarChar(100)
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  applications Application[]

  @@index([tenantId], map: "idx_candidates_tenant")
  @@index([tenantId, status], map: "idx_candidates_tenant_status")
  // Partial UNIQUE index on (tenant_id, email) WHERE deleted_at IS NULL lives in
  // migration SQL only — see 20260627000000_m16_recruiting_candidates/migration.sql.
  // Do NOT change to @@unique (GD-M16-1 Decision 5).
  @@index([tenantId, email], map: "idx_candidates_tenant_email")
  @@map("candidates")
  @@schema("recruiting")
}

// ---------------------------------------------------------------------------
// Schema: recruiting — Application
// Governance authority: GD-M17-1 (2026-06-29)
// Milestone 17: Application Management Foundation
// Approved decisions:
//   - tenantId bare scalar — isolation enforced at query level (SEC-003; GD-M17-1 D15)
//   - tenantId derived from JWT only; never from request body; never in API responses
//   - status VARCHAR(50) default APPLIED; canonical values: APPLIED/SCREENING/INTERVIEW/
//     EVALUATION/OFFER/HIRED/REJECTED/WITHDRAWN (GD-PRE-PHASE3-002 D8; GD-M17-1 D5)
//   - DUPLICATE PREVENTION: enforced as partial unique index in migration SQL
//     (tenant_id, candidate_id, vacancy_id WHERE deleted_at IS NULL
//     AND status NOT IN ('REJECTED', 'WITHDRAWN')) — allows re-application after
//     terminal states (GD-M17-1 Decision 5, Decision 7).
//     DO NOT add @@unique([tenantId, candidateId, vacancyId]) — would generate a
//     full non-partial unique constraint blocking terminal re-application.
//   - Relations to Candidate and Vacancy are one-directional by intent;
//     back-relations on Candidate and Vacancy are added solely for Prisma schema
//     validation — not exposed through service APIs.
//   - interviews Interview[] back-relation added in M18A solely for Prisma schema
//     validation — not consumed by ApplicationService (GD-M18-1 D4).
//   - offers Offer[] back-relation added in M18B solely for Prisma schema
//     validation — OfferService queries the offers table directly (GD-M18-1 D6).
//   - deleted_at per platform soft-delete convention
// ---------------------------------------------------------------------------

model Application {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  candidateId  String    @map("candidate_id") @db.Uuid
  vacancyId    String    @map("vacancy_id") @db.Uuid
  status       String    @default("APPLIED") @db.VarChar(50)
  submittedAt  DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  currentStage String?   @map("current_stage") @db.VarChar(100)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  candidate  Candidate   @relation(fields: [candidateId], references: [id])
  vacancy    Vacancy     @relation(fields: [vacancyId], references: [id], map: "fk_application_vacancy")
  interviews Interview[]
  offers     Offer[]

  @@index([tenantId], map: "idx_applications_tenant")
  @@index([tenantId, candidateId], map: "idx_applications_candidate")
  @@index([tenantId, vacancyId], map: "idx_applications_vacancy")
  @@index([tenantId, status], map: "idx_applications_status")
  // Partial UNIQUE index on (tenant_id, candidate_id, vacancy_id)
  // WHERE deleted_at IS NULL AND status NOT IN ('REJECTED', 'WITHDRAWN')
  // lives in migration SQL only — prevents duplicate active applications while
  // allowing re-application after terminal states (GD-M17-1 Decision 5, Decision 7).
  // Do NOT change to @@unique (would block legitimate re-application).
  // See migration 20260629000000_m17_applications/migration.sql.
  @@map("applications")
  @@schema("recruiting")
}

// ---------------------------------------------------------------------------
// Schema: recruiting — Interview
// Governance authority: GD-M18-1 (2026-06-30)
// Milestone 18A: Interview Management Foundation
// Approved decisions:
//   - tenantId bare scalar — isolation enforced at query level (SEC-003; GD-M18-1 D16)
//   - tenantId derived from JWT only; never from request body; never in API responses
//   - status VARCHAR(50) default SCHEDULED; canonical values: SCHEDULED, COMPLETED,
//     CANCELLED, NO_SHOW (GD-PRE-PHASE3-002 D8; GD-M18-1 D5)
//   - interviewerUserId: nullable; no DB-level FK constraint (GD-PRE-PHASE3-002 D5;
//     GD-M18-1 D4). Service validates user existence and tenant membership at runtime.
//   - Back-relation is on Application (interviews Interview[]) for Prisma schema
//     validation only — not consumed by ApplicationService (GD-M18-1 D4).
//   - deleted_at per platform soft-delete convention
// ---------------------------------------------------------------------------

model Interview {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  applicationId     String    @map("application_id") @db.Uuid
  interviewType     String    @map("interview_type") @db.VarChar(50)
  scheduledAt       DateTime? @map("scheduled_at") @db.Timestamptz(6)
  status            String    @default("SCHEDULED") @db.VarChar(50)
  interviewerName   String?   @map("interviewer_name") @db.VarChar(255)
  interviewerUserId String?   @map("interviewer_user_id") @db.Uuid
  feedback          String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  application Application @relation(fields: [applicationId], references: [id], map: "fk_interview_application")

  @@index([tenantId], map: "idx_interviews_tenant")
  @@index([tenantId, applicationId], map: "idx_interviews_application")
  @@map("interviews")
  @@schema("recruiting")
}

// ---------------------------------------------------------------------------
// Schema: recruiting — Offer
// Governance authority: GD-M18-1 (2026-06-30)
// Milestone 18B: Offer Management Foundation
// Approved decisions:
//   - tenantId bare scalar — isolation enforced at query level (SEC-003; GD-M18-1 D16)
//   - tenantId derived from JWT only; never from request body; never in API responses
//   - status VARCHAR(50) default DRAFT; canonical values: DRAFT, PENDING_APPROVAL,
//     APPROVED, SENT, ACCEPTED, DECLINED, WITHDRAWN (GD-PRE-PHASE3-002 D8; GD-M18-1 D7)
//   - acceptedAt and declinedAt: set by OfferService at the moment of status transition;
//     no withdrawn_at column per GD-M18-1 D7 (updated_at reflects withdrawal time)
//   - Back-relation is on Application (offers Offer[]) for Prisma schema validation only
//     — OfferService queries the offers table directly (GD-M18-1 D6).
//   - Offer acceptance does NOT set application.status to HIRED and does NOT create
//     an employee record — hire-to-employee is M19 scope (GD-M18-1 D3, D9)
//   - Partial UNIQUE index idx_offers_application_active lives in migration SQL only
//     (cannot be expressed as Prisma @@unique — would generate a non-partial constraint).
//     Active = deleted_at IS NULL AND status NOT IN ('DECLINED', 'WITHDRAWN').
//     Re-offer permitted only after DECLINED or WITHDRAWN (GD-M18-1 D6, D10).
//   - deleted_at per platform soft-delete convention
// ---------------------------------------------------------------------------

model Offer {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  applicationId String    @map("application_id") @db.Uuid
  status        String    @default("DRAFT") @db.VarChar(50)
  offerDate     DateTime? @map("offer_date") @db.Timestamptz(6)
  acceptedAt    DateTime? @map("accepted_at") @db.Timestamptz(6)
  declinedAt    DateTime? @map("declined_at") @db.Timestamptz(6)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  application Application @relation(fields: [applicationId], references: [id], map: "fk_offer_application")

  @@index([tenantId], map: "idx_offers_tenant")
  @@index([tenantId, applicationId], map: "idx_offers_application")
  // Partial UNIQUE index on (application_id) WHERE deleted_at IS NULL AND status NOT IN ('DECLINED', 'WITHDRAWN')
  // lives in migration SQL only — enforces one active offer per application; re-offer allowed after
  // DECLINED or WITHDRAWN terminal states (GD-M18-1 D6, D10). Do NOT add @@unique here.
  // See migration 20260630100000_m18b_offers/migration.sql.
  @@map("offers")
  @@schema("recruiting")
}

// ---------------------------------------------------------------------------
// Schema: audit
// Append-only immutable audit trail. tenantId/userId are plain UUID columns
// with no Prisma relations — cascading deletes must never affect audit records.
// Spec reference: spec/05_database_schema.md — Schema: audit / audit_events
// ---------------------------------------------------------------------------

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  action     String   @db.VarChar(100)
  result     String   @default("SUCCESS") @db.VarChar(50)
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_audit_tenant")
  @@index([userId], map: "idx_audit_user")
  @@index([createdAt], map: "idx_audit_created")
  @@map("audit_events")
  @@schema("audit")
}

// ---------------------------------------------------------------------------
// Schema: intelligence
// Reference: governance/GD-M34-1.md — Decisions 14, 15, 16, 17, 18
//
// WorkforceSignalSnapshot is an additive, append-or-update-only historical
// record of Phase 4 intelligence signal computations. It exists ONLY to
// accumulate real computed history for a future, separately-governed
// Workforce Trend Analysis (FR-412) or Demand Forecasting (FR-400)
// milestone. No endpoint reads this table in M34 (GD-M34-1 Decision 18) —
// it is written to and read by nothing except SnapshotWriterService.
//
// scopeId is NOT NULL, defaulting to the zero-UUID sentinel for
// scopeType = 'TENANT' rather than using a nullable column as GD-M34-1
// Decision 15's illustrative snippet showed. This is a deliberate
// implementation-time refinement: PostgreSQL UNIQUE constraints treat every
// NULL as distinct from every other NULL, so a nullable scopeId would
// silently defeat the Decision 17 deduplication guarantee for every
// TENANT-scoped row (the most common case) — concurrent requests could
// each insert a new "unique" NULL-scopeId row instead of colliding on the
// intended daily key. A non-null sentinel makes the compound unique
// constraint enforce the guarantee Decision 17 actually requires.
//
// signalType values written by the current implementation (see
// SnapshotWriterService and its callers): 'VACANCY_RISK',
// 'WORKFORCE_READINESS', 'ATTRITION_RISK' (all three also written with
// scopeType='DEPARTMENT' by DepartmentGapService, one row per non-suppressed
// department, per Decision 16), and four distinct
// 'EXECUTIVE_METRICS_<METRIC>' values — one per independent metric
// (VACANCY_RATE / COVERAGE_RATE / TIME_TO_FILL / HIRING_VELOCITY) rather
// than a single shared 'EXECUTIVE_METRICS' tag, because a shared tag would
// collide on the same dedup key for all four metrics and each write would
// overwrite the previous metric's value instead of preserving all four.
// This is a necessary refinement of Decision 15's illustrative value list,
// documented here per that decision's own instruction that any future
// change to signalType's governed value set be recorded.
model WorkforceSignalSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  signalType     String   @map("signal_type") @db.VarChar(50)
  scopeType      String   @map("scope_type") @db.VarChar(20)
  scopeId        String   @default("00000000-0000-0000-0000-000000000000") @map("scope_id") @db.Uuid
  snapshotDate   DateTime @map("snapshot_date") @db.Date
  score          Decimal? @db.Decimal(6, 2)
  level          String?  @db.VarChar(50)
  confidence     Int      @db.SmallInt
  formulaVersion String   @map("formula_version") @db.VarChar(100)
  computedAt     DateTime @map("computed_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, signalType, scopeType, scopeId, snapshotDate], map: "idx_workforce_signal_snapshots_dedup")
  @@index([tenantId, signalType], map: "idx_workforce_signal_snapshots_tenant_signal")
  @@map("workforce_signal_snapshots")
  @@schema("intelligence")
}
