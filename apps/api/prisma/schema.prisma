// =============================================================================
// Government Workforce Intelligence Platform — Prisma Schema
// Milestone 2: Database Foundation
// Reference: spec/05_database_schema.md, execution/02_phase_1_foundation.md
// =============================================================================
//
// PostgreSQL schemas declared here (Milestone 2 scope):
//   organization — tenants (multi-tenant root; spec: organization.agencies)
//   identity     — users, roles, permissions, role_permissions, user_roles
//   audit        — audit_events (immutable audit trail)
//
// Future schemas added progressively as domains are implemented:
//   workforce, scheduling, recruiting, intelligence, compliance, integration
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "organization", "audit", "workforce"]
}

// ---------------------------------------------------------------------------
// Schema: organization
// Tenant root entity. Every tenant-scoped table carries tenant_id UUID
// referencing this table.
// Spec reference: spec/05_database_schema.md — Schema: organization / agencies
// The platform treats agency and tenant as the same concept at the DB level.
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(100)
  status    String   @default("ACTIVE") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users       User[]
  departments Department[]

  @@map("tenants")
  @@schema("organization")
}

// ---------------------------------------------------------------------------
// Schema: organization — Department
// Spec reference: spec/05_database_schema.md — Schema: organization / departments
// Approved decisions:
//   - code VARCHAR(100) with tenant-scoped unique constraint (Decision 2)
//   - deleted_at per platform soft-delete convention (Decision 3)
//   - agencyId column omitted: Tenant IS Agency (ORG-006); tenantId serves both
//     tenant isolation and agency association roles — adding a separate agencyId
//     FK to the same Tenant row would be redundant.
// ---------------------------------------------------------------------------

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @db.VarChar(100)
  description String?   @db.Text
  status      String    @default("ACTIVE") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  positions Position[]
  employees Employee[]

  @@unique([tenantId, code], map: "idx_departments_tenant_code")
  @@index([tenantId], map: "idx_departments_tenant")
  @@map("departments")
  @@schema("organization")
}

// ---------------------------------------------------------------------------
// Schema: workforce
// Spec reference: spec/05_database_schema.md — Schema: workforce / positions
// Milestone 8: Position Management Foundation (FR-100)
// Approved decisions:
//   - status default DRAFT per full 4-state lifecycle (Decision 1: DRAFT/ACTIVE/FROZEN/CLOSED)
//   - tenantId as bare scalar (no Prisma relation to Tenant) — isolation enforced at query level
//   - departmentId FK to organization.departments — cross-schema relation (multiSchema preview)
//   - deleted_at per platform soft-delete convention
//   - skills/certifications deferred (Decision 3)
// ---------------------------------------------------------------------------

model Position {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  departmentId   String    @map("department_id") @db.Uuid
  title          String    @db.VarChar(255)
  classification String?   @db.VarChar(100)
  salaryBand     String?   @map("salary_band") @db.VarChar(100)
  status         String    @default("DRAFT") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id])
  vacancies  Vacancy[]

  @@index([tenantId], map: "idx_positions_tenant")
  @@index([departmentId], map: "idx_positions_department")
  @@map("positions")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Vacancy
// Spec reference: spec/05_database_schema.md — Schema: workforce / vacancies
// Milestone 11: Vacancy Management (FR-103, FR-104)
// Approved governance decisions:
//   - status/priority/reason stored as VARCHAR per platform convention (no Prisma enums)
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level
//   - filledAt added (not in spec/05): required for Time To Fill metric (directives/03 Reporting Rules)
//   - deleted_at per platform soft-delete convention
//   - 4 indexes: position, status, tenant, createdAt (last two governance additions to spec/05 gaps)
// ---------------------------------------------------------------------------

model Vacancy {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  positionId       String    @map("position_id") @db.Uuid
  priority         String?   @db.VarChar(50)
  reason           String?   @db.VarChar(100)
  status           String    @default("DRAFT") @db.VarChar(50)
  expectedFillDate DateTime? @map("expected_fill_date") @db.Date
  filledAt         DateTime? @map("filled_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  position Position @relation(fields: [positionId], references: [id], map: "fk_vacancy_position")

  @@index([tenantId], map: "idx_vacancies_tenant")
  @@index([positionId], map: "idx_vacancies_position")
  @@index([status], map: "idx_vacancies_status")
  @@index([createdAt], map: "idx_vacancies_created")
  @@map("vacancies")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Employee
// Spec reference: spec/05_database_schema.md — Schema: workforce / employees
// Milestone 12: Employee Management Foundation (FR-110, FR-111, FR-112)
// Approved governance decisions:
//   - employmentStatus @default("PENDING_ONBOARDING") per GD-M12-1 canonical values
//   - employmentStatus stored as VARCHAR per platform convention (no Prisma enum)
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
//   - departmentId FK to organization.departments — cross-schema relation (multiSchema preview)
//   - employeeNumber nullable at DB level per spec/05; required at API level per GD-M12-6
//   - employeeNumber immutable after creation per GD-M12-6 (enforced at service layer)
//   - No positionId field — GD-M12-2: position association deferred to Phase 3 Scheduling
//   - deleted_at per platform soft-delete convention
// ---------------------------------------------------------------------------

model Employee {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  departmentId     String    @map("department_id") @db.Uuid
  employeeNumber   String?   @map("employee_number") @db.VarChar(100)
  firstName        String    @map("first_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  email            String?   @db.VarChar(255)
  employmentStatus String    @default("PENDING_ONBOARDING") @map("employment_status") @db.VarChar(50)
  hireDate         DateTime? @map("hire_date") @db.Date
  terminationDate  DateTime? @map("termination_date") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id])

  employeeSkills         EmployeeSkill[]
  employeeCertifications EmployeeCertification[]

  @@unique([tenantId, employeeNumber], map: "idx_employee_number_tenant")
  @@index([tenantId], map: "idx_employees_tenant")
  @@map("employees")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Skill
// Spec reference: spec/05_database_schema.md — Schema: workforce / skills
// Milestone 13: Skills & Certifications Foundation (FR-113, FR-150)
// Governance decisions:
//   - tenant_id per GD-M13-1 Decision 2 (spec deviation — correction of spec oversight)
//   - created_at, updated_at, deleted_at per GD-M13-1 Decision 7 (shared column confirmation)
//   - tenant-scoped unique constraint on name per GD-M13-2 Decision 8
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
// ---------------------------------------------------------------------------

model Skill {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  category    String?   @db.VarChar(100)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  employeeSkills EmployeeSkill[]

  @@unique([tenantId, name], map: "idx_skills_tenant_name")
  @@index([tenantId], map: "idx_skills_tenant")
  @@map("skills")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — Certification
// Spec reference: spec/05_database_schema.md — Schema: workforce / certifications
// Milestone 13: Skills & Certifications Foundation (FR-114, FR-151, FR-153)
// Governance decisions:
//   - tenant_id per GD-M13-1 Decision 2 (spec deviation — correction of spec oversight)
//   - created_at, updated_at, deleted_at per GD-M13-1 Decision 7 (shared column confirmation)
//   - tenant-scoped unique constraint on name per GD-M13-2 Decision 9
//   - tenantId as bare scalar (no FK to Tenant) — isolation enforced at query level (SEC-003)
// ---------------------------------------------------------------------------

model Certification {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  name               String    @db.VarChar(255)
  issuer             String?   @db.VarChar(255)
  expirationRequired Boolean   @default(false) @map("expiration_required")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  employeeCertifications EmployeeCertification[]

  @@unique([tenantId, name], map: "idx_certifications_tenant_name")
  @@index([tenantId], map: "idx_certifications_tenant")
  @@map("certifications")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — EmployeeSkill
// Spec reference: spec/05_database_schema.md — Schema: workforce / employee_skills
// Milestone 13: Skills & Certifications Foundation (FR-113, FR-150)
// Governance decisions:
//   - Composite PK (employee_id, skill_id) per spec/05 and GD-M13-4 Decision 2
//   - proficiency_level: one of BEGINNER/DEVELOPING/PROFICIENT/ADVANCED/EXPERT
//     (GD-M13-2 Decision 6, directives/14 SKL-210); validated at service layer
//   - verified_at null = self-declared; set = HR-verified (directives/14 SKL-211)
//   - No tenant_id column — isolation derived through employee FK chain (GD-M13-1 Decision 7)
// ---------------------------------------------------------------------------

model EmployeeSkill {
  employeeId       String    @map("employee_id") @db.Uuid
  skillId          String    @map("skill_id") @db.Uuid
  proficiencyLevel String?   @map("proficiency_level") @db.VarChar(50)
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id])
  skill    Skill    @relation(fields: [skillId], references: [id])

  @@id([employeeId, skillId])
  @@index([employeeId], map: "idx_employee_skills_employee")
  @@index([skillId], map: "idx_employee_skills_skill")
  @@map("employee_skills")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: workforce — EmployeeCertification
// Spec reference: spec/05_database_schema.md — Schema: workforce / employee_certifications
// Milestone 13: Skills & Certifications Foundation (FR-114, FR-151, FR-153)
// Governance decisions:
//   - Composite PK (employee_id, certification_id) per spec/05 and GD-M13-4 Decision 2
//   - status VARCHAR(50); canonical values: ACTIVE, EXPIRED, REVOKED (GD-M13-3)
//   - status DEFAULT "ACTIVE" per GD-M13-3 Decision 2
//   - REVOKED is terminal; transition enforcement at service layer (CRT-301)
//   - issue_date and expiration_date stored as DATE per spec/05
//   - No tenant_id column — isolation derived through employee FK chain (GD-M13-1 Decision 7)
//   - expirationDate index: supports FR-153 expiration tracking queries (GD-M13-3 Decision 4)
// ---------------------------------------------------------------------------

model EmployeeCertification {
  employeeId      String    @map("employee_id") @db.Uuid
  certificationId String    @map("certification_id") @db.Uuid
  status          String    @default("ACTIVE") @map("status") @db.VarChar(50)
  issueDate       DateTime? @map("issue_date") @db.Date
  expirationDate  DateTime? @map("expiration_date") @db.Date

  employee      Employee      @relation(fields: [employeeId], references: [id])
  certification Certification @relation(fields: [certificationId], references: [id])

  @@id([employeeId, certificationId])
  @@index([employeeId], map: "idx_employee_certifications_employee")
  @@index([certificationId], map: "idx_employee_certifications_certification")
  @@index([status], map: "idx_employee_certifications_status")
  @@index([expirationDate], map: "idx_employee_certifications_expiration")
  @@map("employee_certifications")
  @@schema("workforce")
}

// ---------------------------------------------------------------------------
// Schema: identity
// Spec reference: spec/05_database_schema.md — Schema: identity
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  status              String    @default("INVITED") @db.VarChar(50)
  lastLoginAt         DateTime? @map("last_login_at")         @db.Timestamptz(6)
  failedLoginAttempts Int       @default(0)                   @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")          @db.Timestamptz(6)
  createdAt           DateTime  @default(now())               @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, email], map: "idx_users_tenant_email")
  @@index([tenantId], map: "idx_users_tenant")
  @@map("users")
  @@schema("identity")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
  @@schema("identity")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
  @@schema("identity")
}

// Role → Permission assignment (many-to-many)
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

// User → Role assignment (many-to-many)
model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("identity")
}

// ---------------------------------------------------------------------------
// Schema: audit
// Append-only immutable audit trail. tenantId/userId are plain UUID columns
// with no Prisma relations — cascading deletes must never affect audit records.
// Spec reference: spec/05_database_schema.md — Schema: audit / audit_events
// ---------------------------------------------------------------------------

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  action     String   @db.VarChar(100)
  result     String   @default("SUCCESS") @db.VarChar(50)
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_audit_tenant")
  @@index([userId], map: "idx_audit_user")
  @@index([createdAt], map: "idx_audit_created")
  @@map("audit_events")
  @@schema("audit")
}
