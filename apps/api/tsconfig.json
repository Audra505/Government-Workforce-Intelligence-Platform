{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2021",
    "outDir": "./dist",
    "baseUrl": "./",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["jest", "node"],
    "paths": {
      "@gov-platform/shared": ["../../packages/shared/src"],
      "@gov-platform/config": ["../../packages/config/src"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
